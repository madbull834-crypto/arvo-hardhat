{
  "name": "arvo-hardhat",
  "version": "1.0.0",
  "description": "ARVO Binary Matrix Smart Contract Suite — BSC BEP-20",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "test:gas": "REPORT_GAS=true npx hardhat test",
    "coverage": "npx hardhat coverage",
    "deploy:testnet": "npx hardhat run scripts/deploy_testnet_full.js --network bscTestnet",
    "deploy:sepolia": "npx hardhat run scripts/deploy_sepolia.js --network sepolia",
    "sync:frontend:sepolia": "node scripts/sync_frontend_config.js sepolia",
    "sync:frontend:bscTestnet": "node scripts/sync_frontend_config.js bscTestnet",
    "sync:frontend:bscMainnet": "node scripts/sync_frontend_config.js bscMainnet",
    "deploy:server:sepolia": "npm run sync:frontend:sepolia && NODE_ENV=production node frontend/server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:restart": "pm2 restart arvo-frontend",
    "deploy:bscTestnet": "npx hardhat run scripts/deploy_testnet_full.js --network bscTestnet",
    "deploy:bscMainnet": "npx hardhat run scripts/deploy_bsc_mainnet.js --network bscMainnet",
    "deploy:bnbMainnet": "npx hardhat run scripts/deploy_bsc_mainnet.js --network bscMainnet",
    "deploy:bnbTestnet": "npx hardhat run scripts/deploy_testnet_full.js --network bscTestnet",
    "deploy:tokens:sepolia": "npx hardhat run scripts/deploy_test_tokens.js --network sepolia",
    "deploy:tokens:bscTestnet": "npx hardhat run scripts/deploy_test_tokens.js --network bscTestnet",
    "deploy:tokens:bnbTestnet": "npx hardhat run scripts/deploy_test_tokens.js --network bscTestnet",
    "deploy:test-tokens:sepolia": "npx hardhat run scripts/deploy_test_tokens.js --network sepolia",
    "deploy:test-tokens:bsc": "npx hardhat run scripts/deploy_test_tokens.js --network bscTestnet",
    "deploy:local": "npx hardhat run scripts/deploy_testnet_full.js",
    "upgrade:sepolia": "npx hardhat run scripts/upgrade_core.js --network sepolia",
    "upgrade:bscTestnet": "npx hardhat run scripts/upgrade_core.js --network bscTestnet",
    "verify": "npx hardhat run scripts/verify.js --network bscTestnet",
    "verify:sepolia": "npx hardhat run scripts/verify_sepolia.js --network sepolia",
    "verify:bnbTestnet": "npx hardhat run scripts/verify.js --network bscTestnet",
    "verify:usdt:sepolia": "npx hardhat run scripts/verify_usdt.js --network sepolia",
    "verify:usdt:bscTestnet": "npx hardhat run scripts/verify_usdt.js --network bscTestnet",
    "verify:usdt:bnbTestnet": "npx hardhat run scripts/verify_usdt.js --network bscTestnet",
    "verify:pool:sepolia": "npx hardhat run scripts/verify_pool.js --network sepolia",
    "verify:pool:bscTestnet": "npx hardhat run scripts/verify_pool.js --network bscTestnet",
    "verify:pool:bnbTestnet": "npx hardhat run scripts/verify_pool.js --network bscTestnet",
    "verify:matrix:sepolia": "npx hardhat run scripts/verify_matrix.js --network sepolia",
    "verify:matrix:bscTestnet": "npx hardhat run scripts/verify_matrix.js --network bscTestnet",
    "verify:matrix:bnbTestnet": "npx hardhat run scripts/verify_matrix.js --network bscTestnet",
    "balances": "npx hardhat run scripts/check_balances.js --network bscTestnet",
    "balances:sepolia": "npx hardhat run scripts/check_balances.js --network sepolia",
    "diagnose:register:sepolia": "npx hardhat run scripts/diagnose_register.js --network sepolia",
    "diagnose:register:bscTestnet": "npx hardhat run scripts/diagnose_register.js --network bscTestnet",
    "migrate:sepolia": "npx hardhat run scripts/migrate_existing_users_sepolia.js --network sepolia",
    "migrate:sepolia:dryrun": "DRY_RUN=true npx hardhat run scripts/migrate_existing_users_sepolia.js --network sepolia",
    "migrate:bscTestnet": "npx hardhat run scripts/migrate_from_legacy.js --network bscTestnet",
    "frontend": "node frontend/server.js",
    "frontend:prod": "NODE_ENV=production node frontend/server.js",
    "node": "npx hardhat node",
    "clean": "npx hardhat clean",
    "mint:usdt:sepolia": "npx hardhat run scripts/mint_test_usdt.js --network sepolia",
    "mint:usdt:bscTestnet": "npx hardhat run scripts/mint_test_usdt.js --network bscTestnet",
    "upgrade:matrix:sepolia": "npx hardhat run scripts/upgrade_matrix.js --network sepolia",
    "validate:matrix:sepolia": "VALIDATE_ONLY=true npx hardhat run scripts/upgrade_matrix.js --network sepolia",
    "deploy:upgradeable:sepolia": "npx hardhat run scripts/deploy_upgradeable.js --network sepolia",
    "deploy:upgradeable:bscTestnet": "npx hardhat run scripts/deploy_upgradeable.js --network bscTestnet",
    "upgrade:upgradeable:sepolia": "npx hardhat run scripts/upgrade_upgradeable.js --network sepolia",
    "upgrade:upgradeable:bscTestnet": "npx hardhat run scripts/upgrade_upgradeable.js --network bscTestnet",
    "validate:upgradeable:sepolia": "VALIDATE_ONLY=true npx hardhat run scripts/upgrade_upgradeable.js --network sepolia",
    "validate:upgradeable:bscTestnet": "VALIDATE_ONLY=true npx hardhat run scripts/upgrade_upgradeable.js --network bscTestnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/mocha": "^10.0.10",
    "dotenv": "^16.0.0",
    "hardhat": "^2.22.19",
    "hardhat-gas-reporter": "^2.0.0",
    "solc": "^0.8.22",
    "solidity-coverage": "^0.8.0",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0"
  }
}
